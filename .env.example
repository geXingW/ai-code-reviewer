APP_NAME=ai-code-reviewer
APP_VERSION=0.1.0-dev
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL / Redis
# Docker Compose overrides host names for container networking. Keep localhost values for local dev.
DATABASE_URL=postgresql+asyncpg://ai_reviewer:ai_reviewer@localhost:5432/ai_code_reviewer
REDIS_URL=redis://localhost:6379/0
POSTGRES_USER=ai_reviewer
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=ai_code_reviewer

# 【必须】Fernet 密钥，用于加密 provider.api_key / project.gitlab_access_token / project.webhook_secret
# 生成方式（推荐）:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 未设置或格式非法时应用将拒绝启动。
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_FERNET_KEY

# GitLab integration
GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_TOKEN=CHANGE_ME_GITLAB_PROJECT_OR_GROUP_ACCESS_TOKEN
GITLAB_WEBHOOK_SECRET=CHANGE_ME_RANDOM_WEBHOOK_SECRET

# Internal management / Jenkins API token.
# Frontend asks for this token in memory only; do not store it in browser storage.
INTERNAL_API_TOKEN=CHANGE...OKEN

# Admin management API authentication (JWT)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE...WORD
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE...BYTES
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=86400

# Review runtime
DEFAULT_REVIEW_ENGINE=llm-direct
CORS_ORIGINS=["http://localhost:5173"]
BACKEND_RELOAD=false
